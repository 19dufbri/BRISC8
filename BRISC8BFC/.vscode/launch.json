    "version": "0.2.0",
    "configurations": [

        {
            "name": "Debug executable 'brisc8bfc'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "run",
                    "--bin=brisc8bfc"
                ]
            },
            "env": {
                "RUST_BACKTRACE": "1"
            },
            "args": ["../SampleCode/SingleFiles/SampleBF.bf", "../SampleCode/SingleFiles/SampleBF.b8a"]
        },
        {
            "name": "Debug unit tests in executable 'brisc8bfc'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "test",
                    "--bin=brisc8bfc"
                ]
            }
        }
    ]
}